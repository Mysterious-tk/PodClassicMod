<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:startColor="#FF343841"
                android:centerColor="#FF101217"
                android:endColor="#FF21050B" />
            <stroke
                android:width="1dp"
                android:color="#8FA52742" />
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF4B4F58"
                android:centerColor="#FF252830"
                android:endColor="#FF090A0D" />
            <stroke
                android:width="1dp"
                android:color="#825F6672" />
        </shape>
    </item>
</layer-list>
